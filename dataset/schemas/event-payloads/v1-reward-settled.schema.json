{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "reward-settled v1 payload",
  "type": "object",
  "additionalProperties": false,
  "required": ["reward_id", "settlement_id", "amount_minor", "currency"],
  "properties": {
    "reward_id": { "type": "string", "pattern": "^rwd_[a-z0-9]{6,}$" },
    "settlement_id": { "type": "string", "pattern": "^stl_[a-z0-9]{6,}$" },
    "amount_minor": { "type": "integer", "minimum": 1, "description": "Integer minor units (pence)." },
    "currency": { "type": "string", "enum": ["GBP"] }
  },
  "examples": [
    {
      "reward_id": "rwd_000001",
      "settlement_id": "stl_000001",
      "amount_minor": 5000,
      "currency": "GBP"
    }
  ]
}
