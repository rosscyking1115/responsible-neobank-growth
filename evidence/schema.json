{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Route C evidence registry",
  "description": "One record per public claim (Plan 4 section 5). No surface may promote a claim above its recorded level.",
  "type": "object",
  "additionalProperties": false,
  "required": ["release_branch", "baseline_commit", "claims"],
  "properties": {
    "release_branch": {
      "type": "string",
      "enum": ["full", "bigquery-only", "mixed-negative", "stopped-cloud"]
    },
    "baseline_commit": { "type": "string", "minLength": 7 },
    "claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "claim_id", "group", "statement", "level", "scope",
          "evidence_paths", "commit", "limitations", "surfaces"
        ],
        "properties": {
          "claim_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
          "group": { "type": "string" },
          "statement": { "type": "string", "minLength": 15 },
          "level": {
            "type": "string",
            "enum": [
              "planned", "configured", "executed-local", "executed-bigquery",
              "measured", "validated-looker", "historical", "illustrative",
              "external"
            ]
          },
          "scope": { "type": "string", "minLength": 5 },
          "evidence_paths": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          },
          "measured_on": { "type": "string" },
          "commit": { "type": "string", "minLength": 3 },
          "limitations": { "type": "string", "minLength": 10 },
          "surfaces": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
