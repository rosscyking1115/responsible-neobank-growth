# Runtime mode: keep local as the default for public demos and CI.
NEOBANK_ENV=local

# Local paths
NEOBANK_DUCKDB_PATH=neobank.duckdb
NEOBANK_CLOUD_EXPORT_DIR=data/cloud_export/demo

# GCP identifiers. Leave blank until you run the cloud path.
GCP_PROJECT_ID=
GCP_LOCATION=europe-west2
GOOGLE_APPLICATION_CREDENTIALS=

# BigQuery datasets
NEOBANK_BQ_LOCATION=EU
NEOBANK_BQ_RAW_DATASET=neobank_raw
NEOBANK_BQ_MART_DATASET=neobank_mart
NEOBANK_BQ_ML_DATASET=neobank_ml
NEOBANK_BQ_MONITORING_DATASET=neobank_monitoring

# Cloud Storage raw landing path
NEOBANK_GCS_RAW_BUCKET=
NEOBANK_GCS_RAW_PREFIX=neobank/raw/demo
NEOBANK_GCS_SCORING_PREFIX=neobank/scoring/activation

# Cost and safety controls
NEOBANK_BQ_MAX_BYTES_BILLED=1000000000
NEOBANK_REQUIRE_GCP_CONFIRMATION=false
